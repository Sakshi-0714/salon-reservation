# ====================
# FRONTEND ENVIRONMENT VARIABLES
# ====================

# React App Backend API URL
# For development: http://localhost:5000
# For production: Your Render backend URL (e.g., https://your-salon-backend.onrender.com)
REACT_APP_API_URL=https://your-salon-backend.onrender.com

# Optional: Analytics or other services can be configured here
# REACT_APP_ANALYTICS_ID=your_analytics_id
