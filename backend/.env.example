# ====================
# DATABASE CONFIGURATION
# ====================
# Railway MySQL Connection Details
DB_HOST=your-railway-mysql-host.railway.app
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-railway-mysql-password
DB_NAME=salon_db
DB_SSL=true
DB_CONNECTION_LIMIT=10

# ====================
# RAZORPAY CONFIGURATION
# ====================
# Razorpay API Keys (Test Mode for development, production after testing)
# Get these from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=rzp_test_your_key_secret

# ====================

# EMAIL CONFIGURATION (NODEMAILER)
# ====================
# Gmail SMTP Configuration
# Generate App Password: https://support.google.com/accounts/answer/185833
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ====================
# FRONTEND CONFIGURATION
# ====================
# Frontend URL (Vercel URL after deployment)
# Multiple origins can be separated by comma
FRONTEND_URL=https://your-salon-app.vercel.app

# ====================
# SERVER CONFIGURATION
# ====================
# Server Port (Render will automatically set PORT env var)
PORT=5000

# ====================
# NODE ENVIRONMENT
# ====================
NODE_ENV=production

