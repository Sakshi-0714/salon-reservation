NODE_ENV=development
PORT=5000

# Railway MySQL. Prefer MYSQL_PUBLIC_URL on Render.
MYSQL_PUBLIC_URL=mysql://root:password@host.railway.app:3306/railway

# Local fallback if no MYSQL_PUBLIC_URL/DATABASE_URL is set.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=Salon123
DB_NAME=salon_db

JWT_SECRET=change_this_before_deploy
FRONTEND_URL=http://localhost:3000

# Razorpay test mode keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx

# Email OTP settings
SMTP_EMAIL=your_gmail@gmail.com
SMTP_PASSWORD=your_gmail_app_password

# Bill delivery. Use whatsapp for WhatsApp Cloud API, smslocal for SMS, or mock for backend log-only messages.
MESSAGE_PROVIDER=whatsapp
WHATSAPP_ACCESS_TOKEN=your_meta_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_meta_phone_number_id
WHATSAPP_API_VERSION=v20.0
# Optional but recommended for business-initiated WhatsApp bill messages.
# Template body variables should be: {{1}} customer name, {{2}} bill number, {{3}} total amount.
WHATSAPP_BILL_TEMPLATE_NAME=staysync_bill_paid
WHATSAPP_TEMPLATE_LANGUAGE=en_US

SMSLOCAL_API_KEY=your_smslocal_api_key
SMSLOCAL_ROUTE=2
SMSLOCAL_SENDER_ID=
# Optional, only if your SMSLocal route/template requires DLT template id.
SMSLOCAL_TEMPLATE_ID=
